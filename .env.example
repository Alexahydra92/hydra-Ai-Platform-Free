# ─── Hydra AI - Environment Variables ────────────────────────
# Copy this file as .env and fill in the values

# Database (SQLite - path to your database file)
DATABASE_URL="file:./db/hydra.db"

# ─── Default AI Provider (used when user doesn't provide their own API key) ───
# Supported: OpenAI, DeepSeek, Groq, Google Gemini, Mistral, OpenRouter, Together AI, etc.
# Any OpenAI-compatible API endpoint

# API Key for the default AI model (REQUIRED)
DEFAULT_API_KEY=your-api-key-here

# Base URL for the default AI provider (auto-set based on provider)
DEFAULT_BASE_URL=https://api.openai.com/v1

# Default model name
DEFAULT_MODEL=gpt-4o-mini

# ─── Legacy Z.ai Support (optional) ───────────────────────────
# If set, will be used as fallback for DEFAULT_API_KEY
# ZAI_API_KEY=your-z-ai-key

# ─── NextAuth Configuration ───────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth (optional - for GitHub login) ───────────────
# Get from https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# ─── Popular Provider Base URLs (for reference) ───────────────
# OpenAI:       https://api.openai.com/v1
# DeepSeek:     https://api.deepseek.com/v1
# Groq:         https://api.groq.com/openai/v1
# Google:       https://generativelanguage.googleapis.com/v1beta/openai
# Mistral:      https://api.mistral.ai/v1
# OpenRouter:   https://openrouter.ai/api/v1
# Together:     https://api.together.xyz/v1
# Anthropic:    https://api.anthropic.com/v1
